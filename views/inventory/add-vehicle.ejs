<h1>Add New Vehicle</h1>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/add-vehicle" method="post">
    <h3>ALL FIELDS ARE REQUIRED</h3>
  <fieldset>
    <legend>Vehicle Information</legend>
    
    <div>
      <label for="classificationList">Classification</label>
      <%- locals.classificationList %>
    </div>

    <div>
      <label for="invMake">Make</label>
      <input 
        type="text" 
        id="invMake" 
        name="inv_make" 
        required 
        value="<%= locals.inv_make || '' %>"
      >
    </div>

    <div>
      <label for="invModel">Model</label>
      <input 
        type="text" 
        id="invModel" 
        name="inv_model" 
        required 
        value="<%= locals.inv_model || '' %>"
      >
    </div>

    <div>
      <label for="invDescription">Description</label>
      <textarea 
        id="invDescription" 
        name="inv_description" 
        required
        rows="5"
      ><%= locals.inv_description || '' %></textarea>
    </div>

    <div>
      <label for="invImage">Image Path</label>
      <input 
        type="text" 
        id="invImage" 
        name="inv_image" 
        required 
        value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>"
      >
    </div>

    <div>
      <label for="invThumbnail">Thumbnail Path</label>
      <input 
        type="text" 
        id="invThumbnail" 
        name="inv_thumbnail" 
        required 
        value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>"
      >
      
    </div>

    <div>
      <label for="invPrice">Price</label>
      <input 
        type="number" 
        id="invPrice" 
        name="inv_price" 
        required 
        step="0.01"
        value="<%= locals.inv_price || '' %>"
         placeholder="decimal or integer"
      >
    </div>
    <div>
      <label for="invYear">Year</label>
      <input 
        type="text" 
        id="invYear" 
        name="inv_year" 
        required 
        pattern="^\d{4}$"
        title="Year must be 4 digits"
        value="<%= locals.inv_year || '' %>"
        placeholder="4-digit year"
      >
    </div>

    <div>
      <label for="invMiles">Miles</label>
      <input 
        type="number" 
        id="invMiles" 
        name="inv_miles" 
        required 
        value="<%= locals.inv_miles || '' %>"
         placeholder="digits only"
      >
    </div>

    <div>
      <label for="invColor">Color</label>
      <input 
        type="text" 
        id="invColor" 
        name="inv_color" 
        required 
        value="<%= locals.inv_color || '' %>"
      >
    </div>

    <div>
      <button type="submit">Add Vehicle</button>
    </div>
  </fieldset>
</form>
