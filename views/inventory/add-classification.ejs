<h1>Add New Classification</h1>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/add-classification" method="post">
  <fieldset>
    <legend>Classification Information</legend>
    
    <div>
      <label for="classificationName">Classification Name</label>
      <input 
        type="text" 
        id="classificationName" 
        name="classification_name" 
        required 
        pattern="^[a-zA-Z0-9]+$"
        title="Cannot contain spaces or special characters. Only letters and numbers allowed."
        value="<%= locals.classification_name || '' %>"
      >
      <span class="notice">Classification name cannot contain spaces or special characters.</span>
    </div>

    <div>
      <button type="submit">Add Classification</button>
    </div>
  </fieldset>
</form>
