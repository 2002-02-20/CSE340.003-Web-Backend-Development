<h1><%= title %></h1>
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>


<h2>Change Information</h2>
<form action="/account/update" method="post">
  <!-- ID oculto para identificar al cliente -->
  <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

  <div>
  <label for="account_firstname">First Name:</label>
  <input type="text" id="account_firstname" name="account_firstname" 
         value="<%= accountData.account_firstname %>" required>
</div>
<div>
  <label for="account_lastname">Last Name:</label>
  <input type="text" id="account_lastname" name="account_lastname" 
         value="<%= accountData.account_lastname %>" required>
</div>

<div>
  <label for="account_email">Email:</label>
  <input type="email" id="account_email" name="account_email" 
         value="<%= accountData.account_email %>" required>
</div>
 <!-- future funtion 
  <% if (locals.loggedin) { %>
  <label for="account_type">Account Type:</label>
  <select id="account_type" name="account_type">
    <option value="Client" <%= accountData.account_type === "Client" ? "selected" : "" %>>Client</option>
    <option value="Employee" <%= accountData.account_type === "Employee" ? "selected" : "" %>>Employee</option>
    <option value="Admin" <%= accountData.account_type === "Admin" ? "selected" : "" %>>Admin</option>
  </select>
<% } else { %>
    
    <% } %>

-->
  <button type="submit">Update Information</button>
</form>


<h2>Change Password</h2>
<form action="/account/update-password" method="post">
   <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

<div>
  <label for="new_password">New Password:</label>
  <span>Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
  <input type="password" id="new_password" name="new_password" 
         required pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
</div>

<!-- future validation 
<div>
  <label for="confirm_password">Confirm New Password:</label>
  <input type="password" id="confirm_password" name="confirm_password" required>
</div>


-->
  <button type="submit">Update Password</button>
</form>